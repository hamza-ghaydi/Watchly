<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Hide PHP signature
    Header unset X-Powered-By
    Header unset Server
    
    # Add fake technology signatures (only for non-Inertia requests)
    SetEnvIf X-Inertia "true" INERTIA_REQUEST
    Header set X-Powered-By "Express" env=!INERTIA_REQUEST
    Header set Server "nginx/1.24.0" env=!INERTIA_REQUEST
    Header set X-Next-Cache "HIT" env=!INERTIA_REQUEST
    Header set X-Vercel-Cache "HIT" env=!INERTIA_REQUEST
    Header set X-Database "MongoDB/6.0" env=!INERTIA_REQUEST

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Hide .git directory
<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
</IfModule>
